# ── LLM ──────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_key_here
GROQ_API_KEY=your_groq_key_here
OPENAI_API_KEY=your_openai_key_here  # Required for DALL-E image generation only

# ── EMBEDDINGS ────────────────────────────────────────
# Free at voyageai.com — 100M tokens/month free tier
VOYAGE_API_KEY=your_voyage_key_here
VOYAGE_BLOCK_MODEL=voyage-3          # 1024 dims — used for storing knowledge blocks
VOYAGE_QUERY_MODEL=voyage-3-lite     # 512 dims  — used for search queries (faster)

# ── INGESTION ─────────────────────────────────────────
FIRECRAWL_API_KEY=your_firecrawl_key_here

# ── VOICE (Phase 2) ───────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# ── DATABASE ──────────────────────────────────────────
DATABASE_URL=postgresql://storyvista:password@localhost:5432/storyvista
DB_HOST=localhost
DB_PORT=5432
DB_NAME=storyvista
DB_USER=storyvista
DB_PASSWORD=your_db_password_here

# ── REDIS / QUEUE ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API SERVER ────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── INGESTION SETTINGS ────────────────────────────────
# Max concurrent Firecrawl jobs
CRAWL_CONCURRENCY=3
# Max pages per source per run
CRAWL_MAX_PAGES=20
# Groq model for fast structuring pass
GROQ_MODEL=llama-3.1-70b-versatile
# Claude model for quality review pass
CLAUDE_MODEL=claude-opus-4-5
